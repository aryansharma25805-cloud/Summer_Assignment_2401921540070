class Solution {
public:
    void inorder(TreeNode* root, vector<int> &arr){
        if(!root) return;
        inorder(root->left, arr);
        arr.push_back(root->val);
        inorder(root->right, arr);
    }
    bool isValidBST(TreeNode* root) {
        vector<int> arr;
        inorder(root,arr);
        for(int i=1;i<arr.size();i++){
            if(arr[i-1] >= arr[i]) return false;
        }
        return true;
    }
};