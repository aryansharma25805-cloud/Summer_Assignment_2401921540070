#include<bits/stdc++.h>
using namespace std;
class Solution {
public:
    int maxSubArray(vector<int>& nums) {
        int maxe =INT_MIN;
        int prefix=0;
        for (int i=0;i<nums.size();i++){
            prefix+=nums[i];
            maxe=max(maxe,prefix);
             if(prefix<0){
                prefix=0;
            }
        }
        return maxe;
    }
};