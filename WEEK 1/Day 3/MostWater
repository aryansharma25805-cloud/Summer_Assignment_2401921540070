#include<bits/stdc++.h>
using namespace std;
class Solution {
public:
    int maxArea(vector<int>& height) {
        int max_area = 0;
        int n = height.size();
        int i = 0, j = n - 1;
        while (i <= j) {
            int mini = min(height[i], height[j]);
            max_area = max(max_area, mini * (j - i));
            if (mini == height[i])
                i++;
            else
                j--;
        }
        return max_area;
    }
};