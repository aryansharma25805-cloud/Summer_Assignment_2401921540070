#include<bits/stdc++.h>
using namespace std;
class Solution {
public:
    bool isPalindrome(string s) {
        int n = s.size();
        string st = "";
        for (int i = 0; i < n; i++) {
            if ((s[i] < 'A' || s[i] > 'Z') && (s[i] < 'a' || s[i] > 'z') &&
                (s[i] < '0' || s[i] > '9')) {
                continue;
            }
            st += tolower(s[i]);
        }
        n = st.size();
        int i = 0, j = n - 1;
        while (i <= j) {
            if (st[i] != st[j])
                return false;
            i++;
            j--;
        }
        return true;
    }
};